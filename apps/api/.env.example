# Jarvis PM API Configuration

# Database (SQLite - zero config)
DATABASE_URL=sqlite+aiosqlite:///./jarvis_pm.db
DATABASE_URL_SYNC=sqlite:///./jarvis_pm.db

# Redis (optional, can be empty)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=jarvis-pm-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI/LLM Configuration
# Kimi (Moonshot AI) - Recommended for Chinese PRD generation
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_MODEL=k2.6-code-preview

# Claude (Anthropic) - Alternative option
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI - Alternative option
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Default AI Provider (kimi/claude/openai)
DEFAULT_AI_PROVIDER=kimi
DEFAULT_AI_MODEL=k2.6-code-preview

# App
DEBUG=True
HOST=0.0.0.0
PORT=8000
