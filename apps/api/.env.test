# Jarvis PM API - Test Environment Configuration
# Generated: 2026-04-11

# Database (SQLite for testing)
DATABASE_URL=sqlite+aiosqlite:///./test_jarvis_pm.db
DATABASE_URL_SYNC=sqlite:///./test_jarvis_pm.db

# Redis (mock for testing)
REDIS_URL=redis://localhost:6379/1

# JWT
SECRET_KEY=test-secret-key-do-not-use-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM Provider配置 (mock for testing)
DEFAULT_LLM_PROVIDER=mock
KIMI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 缓存配置
CACHE_TTL=3600

# 功能开关
ENABLE_LLM_CACHE=false
ENABLE_OUTPUT_VALIDATION=true
ENABLE_WORKFLOW_ENGINE=true

# App
DEBUG=true
HOST=127.0.0.1
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# File storage
UPLOAD_DIR=./test_uploads
MAX_FILE_SIZE=10485760
