# Jarvis PM — Production Environment
# 用于面试展示作品部署
# 注意：不要将此文件提交到 Git！已添加到 .gitignore

# === 数据库 (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/jarvis_pm
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/jarvis_pm

# === Redis 缓存 ===
REDIS_URL=redis://redis:6379/0

# === JWT 安全密钥 (已生成强随机密钥) ===
SECRET_KEY=eQDqUMNN21E82lteh8ThVj6mZlOHCJkUMiNBvsJNKWSixhTC47CSO3hH0fo5MjXumRJjvTINLOS_dGCPYTLyEA
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === AI/LLM 配置 (至少配置一个) ===
# DeepSeek (推荐，PRD 生成最快)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Kimi (中文场景推荐)
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_MODEL=k2.6-code-preview

# Anthropic (备用)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (备用)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# 默认 AI 提供商
DEFAULT_AI_PROVIDER=deepseek
DEFAULT_AI_MODEL=deepseek-v4-flash
DEFAULT_LLM_PROVIDER=deepseek

# === 应用配置 (生产模式) ===
DEBUG=false
HOST=0.0.0.0
PORT=8000
SINGLE_USER_MODE=false

# === CORS 配置 (部署后需要替换为实际域名) ===
# 示例: CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=https://your-domain.com

# === 缓存配置 ===
CACHE_TTL=3600
ENABLE_LLM_CACHE=true

# === 功能开关 ===
ENABLE_OUTPUT_VALIDATION=true
ENABLE_WORKFLOW_ENGINE=true

# === 文件上传 ===
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
